// Windows resources: app icon + version info (Explorer > Properties > Details).
// @tokens@ are filled in by build.rs from Cargo metadata (same idea as the NSIS
// installer.nsi.in template), so the version never drifts from Cargo.toml.
// Compiled by embed-resource for both msvc (rc.exe) and gnu (windres).
#pragma code_page(65001)

// id 1 = the icon the shell uses for the exe
1 ICON "@ICON@"

1 VERSIONINFO
FILEVERSION @VER_CSV@
PRODUCTVERSION @VER_CSV@
FILEFLAGSMASK 0x3fL
FILEFLAGS 0x0L
FILEOS 0x40004L
FILETYPE 0x1L
FILESUBTYPE 0x0L
BEGIN
	BLOCK "StringFileInfo"
	BEGIN
		BLOCK "040904b0"
		BEGIN
			VALUE "CompanyName", "Jim Collier"
			VALUE "FileDescription", "@DESC@"
			VALUE "FileVersion", "@VER_STR@"
			VALUE "InternalName", "silkterm"
			VALUE "LegalCopyright", "© 2026 Jim Collier - GPL-2.0-or-later"
			VALUE "OriginalFilename", "silkterm.exe"
			VALUE "ProductName", "SilkTerm"
			VALUE "ProductVersion", "@VER_STR@"
		END
	END
	BLOCK "VarFileInfo"
	BEGIN
		VALUE "Translation", 0x409, 1200
	END
END
