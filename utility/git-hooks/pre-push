#!/bin/sh
# Local merge gate: before any push that updates main or dev, run the fast
# verify pass (cicd.bash --gate: fmt --check + clippy -D warnings + tests).
# Feature-branch pushes are not gated (they get verified at merge time).
# Bypass for an emergency: git push --no-verify, or SKIP_GATE=1 git push.
#
# Activate once per clone:  git config core.hooksPath utility/git-hooks
set -eu

[ "${SKIP_GATE:-0}" = "1" ] && exit 0

# stdin: "<local_ref> <local_sha> <remote_ref> <remote_sha>" per ref being pushed.
gated=0
main_local=""
main_remote=""
while read -r local_ref local_sha remote_ref remote_sha; do
	case "$remote_ref" in
		refs/heads/main|refs/heads/dev)
			# deleting the branch pushes the zero sha - nothing to verify
			case "$local_sha" in *[!0]*) gated=1 ;; esac
			;;
	esac
	# main is release-only: remember its shas for the version-bump check below
	case "$remote_ref" in
		refs/heads/main)
			case "$local_sha" in *[!0]*) main_local="$local_sha"; main_remote="$remote_sha" ;; esac
			;;
	esac
done

# Release guard: a push to main must strictly INCREASE the version. main is where
# releases are cut, so shipping the same-or-lower version is a mistake - block it
# here (before the slower gate) so a forgotten Cargo.toml bump can't reach main.
if [ -n "$main_local" ]; then
	manifest=source/Cargo.toml
	read_ver() { git show "$1:$manifest" 2>/dev/null | sed -n 's/^version *= *"\(.*\)".*/\1/p' | head -1; }
	# ver_gt A B: exit 0 iff A > B by semver precedence (numeric core fields;
	# a prerelease ranks below its release; numeric ids below alphanumeric; ASCII).
	ver_gt() {
		LC_ALL=C awk -v a="$1" -v b="$2" '
		function cmp(a, b,   ca, cb, pa, pb, xa, xb, ia, ib, na, nb, m, i, va, vb, x, y, xn, yn) {
			sub(/\+.*/, "", a); sub(/\+.*/, "", b)
			ca = a; pa = ""; if (index(a, "-")) { ca = substr(a, 1, index(a,"-")-1); pa = substr(a, index(a,"-")+1) }
			cb = b; pb = ""; if (index(b, "-")) { cb = substr(b, 1, index(b,"-")-1); pb = substr(b, index(b,"-")+1) }
			na = split(ca, xa, "."); nb = split(cb, xb, ".")
			m = (na > nb) ? na : nb
			for (i = 1; i <= m; i++) {
				va = (i <= na) ? xa[i]+0 : 0; vb = (i <= nb) ? xb[i]+0 : 0
				if (va > vb) return 1; if (va < vb) return -1
			}
			if (pa == "" && pb == "") return 0
			if (pa == "") return 1; if (pb == "") return -1
			na = split(pa, ia, "."); nb = split(pb, ib, ".")
			m = (na < nb) ? na : nb
			for (i = 1; i <= m; i++) {
				x = ia[i]; y = ib[i]; xn = (x ~ /^[0-9]+$/); yn = (y ~ /^[0-9]+$/)
				if (xn && yn) { if (x+0 > y+0) return 1; if (x+0 < y+0) return -1 }
				else if (xn && !yn) return -1
				else if (!xn && yn) return 1
				else { if (x > y) return 1; if (x < y) return -1 }
			}
			if (na > nb) return 1; if (na < nb) return -1
			return 0
		}
		BEGIN { exit (cmp(a, b) > 0) ? 0 : 1 }
		'
	}
	newv=$(read_ver "$main_local")
	[ -n "$newv" ] || { echo "pre-push: cannot read version from $manifest on the pushed commit" >&2; exit 1; }
	# zero remote sha = main does not exist yet (first push), nothing to compare
	case "$main_remote" in
		*[!0]*)
			oldv=$(read_ver "$main_remote")
			if [ -n "$oldv" ] && ! ver_gt "$newv" "$oldv"; then
				echo "pre-push: version $newv must be greater than $oldv on main - bump $manifest (and the README Release badge) before releasing. (SKIP_GATE=1 or --no-verify to override)" >&2
				exit 1
			fi
			;;
	esac
fi

[ "$gated" = "1" ] || exit 0

echo "pre-push: gating push to main/dev (cicd.bash --gate; --no-verify skips)" >&2
exec "$(git rev-parse --show-toplevel)/cicd/cicd.bash" --gate
